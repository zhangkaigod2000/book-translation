# ========== 服务基础配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=5020
CORS_ORIGIN=http://localhost:5021

# ========== LLM 后端选择 ==========
# 可选值: vllm, ollama, openai
# - vllm: 本地或远程 vLLM 服务 (OpenAI 兼容)
# - ollama: 本地 Ollama 服务
# - openai: OpenAI 标准 API (硅基流动、DeepSeek、OpenAI 等)
LLM_BACKEND=openai

# ========== vLLM 推理配置 (当 LLM_BACKEND=vllm 时使用) ==========
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL_NAME=Qwen-7B-Chat
VLLM_API_KEY=sk-local

# ========== Ollama 推理配置 (当 LLM_BACKEND=ollama 时使用) ==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen2.5:7b

# ========== OpenAI 标准 API 配置 (当 LLM_BACKEND=openai 时使用) ==========
# 支持：硅基流动(SiliconFlow)、DeepSeek、OpenAI、Azure OpenAI 等
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL_NAME=gpt-3.5-turbo

# ========== 常用在线 LLM 服务配置示例 ==========

# 【硅基流动 SiliconFlow】
# LLM_BACKEND=openai
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# 其他模型选项:
#   - Qwen/Qwen2.5-72B-Instruct
#   - deepseek-ai/DeepSeek-V2.5
#   - THUDM/glm-4-9b-chat

# 【DeepSeek】
# LLM_BACKEND=openai
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL_NAME=deepseek-chat

# 【OpenAI】
# LLM_BACKEND=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL_NAME=gpt-4o-mini

# 【Azure OpenAI】
# LLM_BACKEND=openai
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_MODEL_NAME=your-deployment-name

# ========== 通用 LLM 配置 ==========
LLM_TEMPERATURE=0.05
LLM_MAX_TOKENS=60000
LLM_TIMEOUT=1200

# ========== 小说翻译核心配置（人名一致性专用） ==========
SOURCE_LANGUAGE=Chinese
TARGET_LANGUAGE=English
AUTO_DETECT_CHAPTER=true
GLOBAL_GLOSSARY_MEMORY=true
FORCE_NAME_CONSISTENCY=true
MERGE_ALIAS=true
MAX_CHUNK_PER_CHAPTER=8000
CONSISTENCY_CHECK_ENABLE=true

# ========== 章节识别正则配置 ==========
CHAPTER_REGEX=^第.{1,5}章.*$
TITLE_KEEP_FORMAT=true

# ========== 数据库持久化 ==========
DATABASE_URL=sqlite:///./novel_translate.db
SAVE_GLOSSARY_TO_DB=true
